{
  "name": "@mm-crypto-bot/tui",
  "version": "0.1.0",
  "type": "module",
  "main": "./src/index.tsx",
  "scripts": {
    "build": "bun build src/index.tsx --target=bun --outdir=dist --format=esm --external react-devtools-core",
    "dev": "bun run src/index.tsx",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "bun test src",
    "coverage": "bun test src --coverage --coverage-reporter=lcov --coverage-dir=coverage",
    "clean": "rm -rf .turbo *.tsbuildinfo dist coverage"
  },
  "dependencies": {
    "@mm-crypto-bot/shared": "workspace:*",
    "@mm-crypto-bot/core": "workspace:*",
    "ink": "7.1.0",
    "react": "19.2.7"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/react": "19.2.0",
    "react-devtools-core": "6.1.1",
    "typescript": "6.0.3"
  }
}
