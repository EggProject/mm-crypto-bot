{
  "name": "@mm/bot",
  "version": "0.0.0",
  "private": true,
  "description": "Futtatható bináris — paper/live indító az mm-crypto-bot rendszer összefogására",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "mm-bot": "./src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts start",
    "tui": "bun run src/index.ts tui",
    "dev": "bun run --watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@mm/core": "workspace:*",
    "@mm/exchange": "workspace:*",
    "@mm/paper": "workspace:*",
    "@mm/shared": "workspace:*",
    "@mm/tui": "workspace:*"
  },
  "devDependencies": {
    "typescript": "6.0.3"
  }
}
