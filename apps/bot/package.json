{
  "name": "@mm-crypto-bot/bot",
  "version": "0.1.0",
  "type": "module",
  "main": "./src/index.ts",
  "bin": {
    "mm-bot": "./src/index.ts"
  },
  "scripts": {
    "build": "bun build src/index.ts --target=bun --outdir=dist --format=esm --external protobufjs",
    "dev": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "bun test src",
    "coverage": "bun test src --coverage --coverage-reporter=text --coverage-reporter=lcov --coverage-dir=coverage",
    "coverage:text": "bun test src --coverage --coverage-reporter=text",
    "coverage:lcov": "bun test src --coverage --coverage-reporter=lcov --coverage-dir=coverage",
    "clean": "rm -rf .turbo *.tsbuildinfo dist coverage"
  },
  "dependencies": {
    "@mm-crypto-bot/backtest": "workspace:*",
    "@mm-crypto-bot/core": "workspace:*",
    "@mm-crypto-bot/exchange": "workspace:*",
    "@mm-crypto-bot/paper": "workspace:*",
    "@mm-crypto-bot/shared": "workspace:*",
    "@mm-crypto-bot/tui": "workspace:*",
    "picocolors": "^1.1.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/react": "19.2.0",
    "ink-testing-library": "4.0.0",
    "react": "19.2.7",
    "typescript": "6.0.3"
  }
}