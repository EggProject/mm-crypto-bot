{
  "name": "@mm-crypto-bot/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --no-error-on-unmatched-pattern --max-warnings=0 \"src/**/*.{ts,tsx}\" \"e2e/**/*.{ts,tsx}\" \"e2e-ct/**/*.{ts,tsx}\"",
    "test": "bun test --pass-with-no-tests src/",
    "e2e": "playwright test --reporter=line",
    "e2e:full": "playwright test --reporter=line",
    "e2e:headed": "playwright test --reporter=line --headed",
    "e2e:ct": "playwright test --config=playwright-ct.config.ts --reporter=line",
    "e2e:ct:headed": "playwright test --config=playwright-ct.config.ts --reporter=line --headed",
    "e2e:all": "bun run e2e:ct && bun run e2e"
  },
  "dependencies": {
    "lightweight-charts": "^5.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/experimental-ct-react": "^1.61.1",
    "@playwright/test": "^1.49.0",
    "@types/istanbul-lib-coverage": "^2.0.6",
    "@types/node": "^22.13.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "bun-types": "^1.1.0",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.1.7",
    "msw": "^2.15.0",
    "nyc": "^17.1.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-istanbul": "^9.0.1"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
