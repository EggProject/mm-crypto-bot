{
  "name": "mm-crypto-bot",
  "private": true,
  "version": "0.1.0",
  "description": "Multi-exchange crypto trading bot — bybit.eu spot+spot margin, paper-trading, backtest, TUI.",
  "type": "module",
  "engines": {
    "bun": ">=1.3.14",
    "node": ">=22"
  },
  "packageManager": "bun@1.3.14",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "coverage": "turbo run coverage",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\""
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/bun": "1.3.14",
    "@types/react": "19.2.0",
    "@tsconfig/bases": "1.0.25",
    "@typescript-eslint/eslint-plugin": "8.62.1",
    "@typescript-eslint/parser": "8.62.1",
    "eslint": "10.6.0",
    "eslint-plugin-security": "4.0.1",
    "prettier": "3.9.4",
    "turbo": "2.10.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1"
  },
  "dependencies": {
    "ccxt": "4.5.64",
    "ink": "7.1.0",
    "react": "19.2.7",
    "zod": "4.4.3"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "esbuild",
    "turbo"
  ]
}