{
  "name": "mm-crypto-bot",
  "version": "0.0.0",
  "private": true,
  "description": "Bun + Turborepo + TS ultra-strict monorepo scaffold az mm-crypto-bot projekthez",
  "type": "module",
  "engines": {
    "bun": ">=1.3.14",
    "node": ">=22"
  },
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "coverage": "turbo run coverage",
    "backtest": "bun run --filter @mm/backtest backtest",
    "paper": "bun run --filter @mm/paper paper",
    "tui": "bun run --filter @mm/tui tui",
    "start": "echo 'not implemented yet: ez a későbbi fázisban a bot indítója lesz (paper/live)' && exit 1",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@tsconfig/bases": "1.0.25",
    "@types/node": "^22.13.0",
    "@typescript-eslint/eslint-plugin": "8.62.1",
    "@typescript-eslint/parser": "8.62.1",
    "eslint": "10.6.0",
    "eslint-plugin-security": "4.0.1",
    "globals": "^17.7.0",
    "turbo": "2.10.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vitest": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "bun-types": "1.3.14"
  },
  "dependencies": {
    "ccxt": "4.5.64"
  }
}
