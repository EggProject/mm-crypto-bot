{
  "name": "@mm-crypto-bot/exchange",
  "version": "0.0.1",
  "description": "CCXT Pro bybit.eu SPOT feed wrapper — REST + WS illesztés a felsőbb rétegekhez",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "echo 'exchange: ts-only, no emit'",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "bun test src tests",
    "coverage": "bun test src tests --coverage --coverage-reporter=lcov --coverage-dir=coverage",
    "clean": "rm -rf .turbo *.tsbuildinfo coverage"
  },
  "dependencies": {
    "@mm-crypto-bot/shared": "workspace:*",
    "ccxt": "4.5.64"
  },
  "devDependencies": {
    "typescript": "6.0.3"
  }
}
