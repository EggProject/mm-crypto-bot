{
  "name": "@mm-crypto-bot/tui",
  "version": "0.1.0",
  "description": "Ink-alap\u00fa TUI v\u00e1z \u2014 terminal user interface a bot \u00e1llapot\u00e1nak megjelen\u00edt\u00e9s\u00e9hez \u00e9s vez\u00e9rl\u00e9s\u00e9hez",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "tui": "bun run src/index.tsx",
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "bun test src",
    "coverage": "bun test src --coverage --coverage-reporter=lcov --coverage-dir=coverage",
    "clean": "rm -rf .turbo *.tsbuildinfo dist coverage"
  },
  "dependencies": {
    "@mm-crypto-bot/paper": "workspace:*",
    "@mm-crypto-bot/shared": "workspace:*",
    "ink": "7.1.0",
    "react": "19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/bun": "1.3.14",
    "react-devtools-core": "6.1.1",
    "typescript": "6.0.3",
    "ink-testing-library": "^4.0.0"
  }
}
