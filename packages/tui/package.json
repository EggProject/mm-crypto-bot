{
  "name": "@mm/tui",
  "version": "0.0.0",
  "private": true,
  "description": "Ink-alapú TUI váz — terminal user interface a bot állapotának megjelenítéséhez és vezérléséhez",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "tui": "bun run src/index.tsx",
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@mm/paper": "workspace:*",
    "@mm/shared": "workspace:*",
    "ink": "7.1.0",
    "react": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "typescript": "6.0.3"
  }
}
