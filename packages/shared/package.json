{
  "name": "@mm-crypto-bot/shared",
  "version": "0.1.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./config": "./src/config.ts",
    "./utils": "./src/utils.ts",
    "./logger": "./src/logger.ts"
  },
  "scripts": {
    "build": "echo 'shared: ts-only, no emit'",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "bun test src",
    "coverage": "bun test src --coverage --coverage-reporter=text --coverage-reporter=lcov --coverage-dir=coverage",
    "clean": "rm -rf .turbo *.tsbuildinfo coverage",
    "coverage:text": "bun test src --coverage --coverage-reporter=text",
    "coverage:lcov": "bun test src --coverage --coverage-reporter=lcov --coverage-dir=coverage"
  },
  "dependencies": {
    "ccxt": "4.5.64",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "typescript": "6.0.3"
  }
}
