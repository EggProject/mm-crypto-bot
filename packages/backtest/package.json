{
  "name": "@mm-crypto-bot/backtest",
  "version": "0.1.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "echo 'backtest: ts-only, no emit'",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "bun test src",
    "coverage": "bun test src --coverage --coverage-reporter=lcov --coverage-dir=coverage",
    "clean": "rm -rf .turbo *.tsbuildinfo coverage",
    "coverage:text": "bun test src --coverage --coverage-reporter=text",
    "coverage:lcov": "bun test src --coverage --coverage-reporter=lcov --coverage-dir=coverage"
  },
  "dependencies": {
    "@mm-crypto-bot/core": "workspace:*",
    "@mm-crypto-bot/shared": "workspace:*"
  },
  "devDependencies": {
    "typescript": "6.0.3"
  }
}
