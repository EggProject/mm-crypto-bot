{
  "name": "@mm-crypto-bot/backtest-tools",
  "version": "0.1.0",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "echo 'backtest-tools: ts-only, no emit'",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "bun test src",
    "coverage": "bun test src --coverage --coverage-reporter=lcov --coverage-dir=coverage",
    "download-ohlcv": "bun run src/cli/download-ohlcv.ts",
    "baseline": "bun run src/cli/run-baseline.ts",
    "sweep": "bun run src/cli/run-sweep.ts",
    "oos": "bun run src/cli/run-oos.ts",
    "report": "bun run src/cli/generate-report.ts",
    "clean": "rm -rf .turbo *.tsbuildinfo coverage"
  },
  "dependencies": {
    "@mm-crypto-bot/backtest": "workspace:*",
    "@mm-crypto-bot/core": "workspace:*",
    "@mm-crypto-bot/exchange": "workspace:*",
    "@mm-crypto-bot/shared": "workspace:*",
    "ccxt": "4.5.64"
  },
  "devDependencies": {
    "typescript": "6.0.3"
  }
}