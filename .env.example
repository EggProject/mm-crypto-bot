# ============================================================================
#  mm-crypto-bot — .env.example
#  Ez a fájl a repository-ban marad, és a lehetséges környezeti változók
#  dokumentációja. A .env fájlt NE commit-old (titkok!).
#  Másolás: `cp .env.example .env && fill in`.
# ============================================================================

# === Üzemeltetési mód =======================================================
# 'paper' | 'live' — a `bun start` vagy `bun run apps/bot` indítása előtt
# Production éles (valódi pénz) módhoz mindig 'live' legyen, és a
# BYBIT_EU_API_KEY/SECRET valódi értékek legyenek.
BUN_ENV=paper

# === Bybit.eu (CCXT `bybiteu` ID-hoz) ======================================
# A `docs/research/stack-findings.md` §1.4 szerint a bybit.eu-n NINCS publikus
# sandbox, ezért a 'paper' mód a saját paper-emulátort használja.
# A valódi éles kereskedéshez az alábbi két változó értéke legyen kitöltve.
# ----------------------------------------------------------------------
# FIGYELEM: A valódi API kulcsokkal rendelkező .env fájlt SOHA ne commit-old,
# és a kulcsokon legyen withdraw letiltva (IP whitelisten kívül)!
# ----------------------------------------------------------------------
BYBIT_EU_API_KEY=your_api_key_here
BYBIT_EU_SECRET=your_api_secret_here

# === Stratégia-konfiguráció =================================================
# A kiválasztott stratégia: MTF-Trend-Konfluencia Kompozit v1.0
# (Donchian+Supertrend HTF szűrő + BB+RSI MTF setup + RSI cross-back LTF trigger)
# Részletek: docs/research/selected-strategy.md
# ----------------------------------------------------------------------

# Időkeretek (cron kifejezés, ISO 8601 duration vagy ms — lásd későbbi fázis)
STRATEGY_HTF_TIMEFRAME=4h
STRATEGY_MTF_TIMEFRAME=1h
STRATEGY_LTF_TIMEFRAME=15m

# Position-sizing és kockázat (1/4-Kelly alap, 1% risk/trade, 15% DD kill-switch)
STRATEGY_RISK_PER_TRADE=0.01
STRATEGY_KELLY_FRACTION=0.25
STRATEGY_MAX_DRAWDOWN=0.15

# === Exchange rate limit (CCXT) ============================================
# Alap: 100 ms (= 10 req/sec). A bybit V5 biztonságos alapértéke.
CCXT_RATE_LIMIT_MS=100

# === Logolás ===============================================================
# Nincs alapértelmezetten — a `packages/shared` logger struktúrát biztosít.
LOG_LEVEL=info
