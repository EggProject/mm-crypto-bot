# ============================================================================
#  mm-crypto-bot — .env.example
#  Template for local environment variables. Copy to `.env` and fill in
#  real values. **NEVER commit `.env`** — it's in `.gitignore`.
#
#  This file documents every env var the bot reads at runtime. Variables
#  not consumed by the bot are deliberately omitted (no dead documentation).
#
#  Reading order:
#    1. Section 1 — Bot config path
#    2. Section 2 — bybit.eu (CCXT `bybiteu`) credentials
#    3. Section 3 — Exchange rate limit (CCXT)
#    4. Section 4 — Logging
#
#  For the full operational workflow, see `apps/bot/README.md` §7.
# ============================================================================

# ============================================================================
# 1) Bot configuration
# ============================================================================
# Path to the bot config file (TOML). The bot is config-driven — every
# runtime decision is sourced from this file. Default (when unset):
# `apps/bot/config/default.toml`. Override for production with a
# `config/prod.toml` (see README §7).
#
# Examples:
#   BOT_CONFIG=apps/bot/config/default.toml
#   BOT_CONFIG=config/prod.toml
#   BOT_CONFIG=/etc/mm-bot/prod.toml
BOT_CONFIG=apps/bot/config/default.toml


# ============================================================================
# 2) bybit.eu (CCXT `bybiteu`)
# ============================================================================
# Real API credentials for the bybit.eu exchange. The bot uses these ONLY
# when `bot.mode = "live"` AND the config's `exchange.id = "bybiteu"`.
# In paper mode the bot never talks to the exchange, so these are unused.
#
# ......... SECURITY .........................
# - NEVER commit `.env`. Withdraw must be disabled on the key (bybit.eu
#   account-side setting). IP-whitelist the bot's host.
# - The keys are read by `apps/bot/src/cli/commands/start.ts` at startup
#   and passed into the CCXT client.
# - For the paper phase, use bybit.eu's test keys (or any fake values
#   in paper mode — they won't be contacted).
# ......... END SECURITY .....................
#
# Set both variables:
#   BYBIT_EU_API_KEY=your_api_key_here
#   BYBIT_EU_SECRET=your_api_secret_here
#
# Or for paper mode, leave blank (the bot will warn but not error).
BYBIT_EU_API_KEY=your_api_key_here
BYBIT_EU_SECRET=your_api_secret_here


# ============================================================================
# 3) Exchange rate limit (CCXT)
# ============================================================================
# CCXT `enableRateLimit` uses this value as the inter-request delay.
# bybit.eu's safe default is 100ms (= 10 req/sec). The config's
# `exchange.rate_limit_ms` field overrides this if set; this env var
# is a global fallback.
#
# Range: 10-10000 ms. bybit.eu production: 100 ms recommended.
CCXT_RATE_LIMIT_MS=100


# ============================================================================
# 4) Logging
# ============================================================================
# Bot log level. One of: "debug" | "info" | "warn" | "error".
# Overrides the config's `[bot].log_level` field.
#
# In production, "info" is the right default. "debug" is verbose —
# only for troubleshooting.
LOG_LEVEL=info
